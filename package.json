{
  "name": "jwt-dashboard",
  "private": true,
  "workspaces": [
    "express-backend",
    "react-frontend"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm run dev --workspace=express-backend",
    "dev:frontend": "npm run dev --workspace=react-frontend",
    "build": "npm run build --workspace=react-frontend && npm run build --workspace=express-backend"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "npm-run-all": "^4.1.5"
  }
}
